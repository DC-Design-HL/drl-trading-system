[Unit]
Description=DRL Trading System - Local API Server
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/.openclaw/projects/drl-trading-system/repo
EnvironmentFile=/root/.openclaw/projects/drl-trading-system/repo/.env
ExecStart=/usr/bin/python3 /root/.openclaw/projects/drl-trading-system/repo/start_local_server.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target

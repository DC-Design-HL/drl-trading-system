        <mxCell id="sltptitle" value="&lt;b&gt;🎯 Stop Loss / Take Profit Logic&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="480" y="555" width="240" height="20" as="geometry" />
        </mxCell>
        
        <mxCell id="sltpdetail" value="&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b&gt;Adaptive SL/TP (ATR-based):&lt;/b&gt;&lt;br&gt;• Higher volatility → Wider stops&lt;br&gt;• Lower volatility → Tighter stops&lt;br&gt;• SL: 0.8% - 3.0% (dynamic)&lt;br&gt;• TP: 1.5% - 6.0% (dynamic)&lt;br&gt;&lt;br&gt;&lt;b&gt;Trailing Stop:&lt;/b&gt;&lt;br&gt;• Activates when profit &gt; TP * 50%&lt;br&gt;• Trails at SL% from highest point&lt;br&gt;• Locks in profits on pullbacks&lt;br&gt;&lt;br&gt;&lt;b&gt;Kelly Position Sizing:&lt;/b&gt;&lt;br&gt;• Uses trade history (last 50 trades)&lt;br&gt;• Half-Kelly for safety (10% - 75%)&lt;/div&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="410" y="575" width="190" height="165" as="geometry" />
        </mxCell>
        
        <mxCell id="sltpformula" value="&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b&gt;LONG Exit Conditions:&lt;/b&gt;&lt;br&gt;• Stop Loss: price ≤ entry × (1 - SL%)&lt;br&gt;• Take Profit: price ≥ entry × (1 + TP%)&lt;br&gt;• Trailing: price drops SL% from high&lt;br&gt;&lt;br&gt;&lt;b&gt;SHORT Exit Conditions:&lt;/b&gt;&lt;br&gt;• Stop Loss: price ≥ entry × (1 + SL%)&lt;br&gt;• Take Profit: price ≤ entry × (1 - TP%)&lt;br&gt;• Trailing: price rises SL% from low&lt;/div&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="600" y="575" width="190" height="165" as="geometry" />
        </mxCell>

